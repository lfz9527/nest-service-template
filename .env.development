# ===========================================
# 开发环境配置
# ===========================================

# Prisma 数据库连接地址
DATABASE_URL=mysql://root:root@localhost:3306/xt_db

# Session 签名密钥
SESSION_SECRET=123456ABCabc_++

# Session 数据库连接
SESSION_DB_HOST=localhost
SESSION_DB_PORT=3306
SESSION_DB_USER=root
SESSION_DB_PASSWORD=root
SESSION_DB_NAME=xt_db

# Session Cookie 有效期（毫秒），86400000 = 24 小时
SESSION_MAX_AGE=86400000
