# ===========================================
# 开发环境配置
# ===========================================

# Prisma 数据库连接地址
DATABASE_URL=mysql://root:password@localhost:3306/dashboard_dev

# Session 签名密钥
SESSION_SECRET=dev-secret-key

# Session 数据库连接
SESSION_DB_HOST=localhost
SESSION_DB_PORT=3306
SESSION_DB_USER=root
SESSION_DB_PASSWORD=password
SESSION_DB_NAME=dashboard_dev

# Session Cookie 有效期（毫秒），86400000 = 24 小时
SESSION_MAX_AGE=86400000
