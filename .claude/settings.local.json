{
  "permissions": {
    "allow": [
      "Bash(bash *)",
      "Skill(superpowers:writing-plans)",
      "Skill(superpowers:subagent-driven-development)",
      "Bash(npm init *)",
      "Bash(npm install *)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-doc-update.sh",
            "if": "Bash(git commit *)",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-doc-update.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
