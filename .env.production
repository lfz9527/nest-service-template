# ===========================================
# 生产环境配置
# 部署时替换为实际生产环境参数
# ===========================================

# Prisma 数据库连接地址
DATABASE_URL=mysql://user:password@prod-host:3306/dashboard_prod

# Session 签名密钥（务必使用强随机字符串）
SESSION_SECRET=

# Session Cookie 有效期（毫秒），86400000 = 24 小时
SESSION_MAX_AGE=86400000
