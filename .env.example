# ===========================================
# 环境配置模板
# 复制此文件为 .env.development 或 .env.production
# ===========================================

# Prisma 数据库连接地址
DATABASE_URL=mysql://user:password@host:port/database

# Session 签名密钥（使用 openssl rand -hex 64 生成强随机密钥）
SESSION_SECRET=change-me-to-a-random-string

# Session Cookie 有效期（毫秒），86400000 = 24 小时
SESSION_MAX_AGE=86400000

# Session 登录模式：single（单机登录，一个账号仅一个活跃 Session）| multi（多机登录，默认）
SESSION_MODE=multi

# Session sameSite 属性：lax | strict | none
SESSION_SAME_SITE=lax

# 端口号
PORT=3000

# bcrypt 加密盐轮数
BCRYPT_SALT_ROUNDS=10

# 默认页码
DEFAULT_PAGE=1

# 默认每页条数
DEFAULT_PAGE_SIZE=10

# 密码最小长度
PASSWORD_MIN_LENGTH=6

# MySQL 默认端口（DATABASE_URL 未指定端口时使用）
DB_DEFAULT_PORT=3306

# 验证码字符数量
CAPTCHA_SIZE=4

# 验证码干扰线数量
CAPTCHA_NOISE=2

# 验证码接口限流时间窗口（秒）
RATE_LIMIT_CAPTCHA_WINDOW_SECONDS=60

# 验证码接口窗口内最大请求数
RATE_LIMIT_CAPTCHA_MAX=10

# 登录接口限流时间窗口（秒）
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60

# 登录接口窗口内最大请求数
RATE_LIMIT_LOGIN_MAX=5

# 限流记录内存清理间隔（毫秒）
RATE_LIMIT_CLEANUP_INTERVAL_MS=60000

# 日志级别：trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# 日志文件路径
LOG_FILE_PATH=./logs/app.log

# 是否启用 pretty 格式（开发=true 生产=false）
LOG_PRETTY=false

# 日志保留天数
LOG_RETENTION_DAYS=7

# 单文件最大大小
LOG_MAX_FILE_SIZE=10m

# 生产环境强制开启 Swagger 文档（设为 true 启用 /api-docs）
# 开发环境始终开启，无需配置
# SWAGGER_ENABLED=true
