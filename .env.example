# ===========================================
# 配置模板
# 开发环境：复制 .env.development 为 .env.development.local
# 生产环境：复制 .env.production 为 .env.production.local
# *.local 文件已在 .gitignore 中排除
# ===========================================

# Prisma 数据库连接地址
DATABASE_URL=mysql://root:password@localhost:3306/dashboard

# Session 签名密钥
SESSION_SECRET=change-me

# Session Cookie 有效期（毫秒），86400000 = 24 小时
SESSION_MAX_AGE=86400000
